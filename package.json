{
  "name": "aethel",
  "version": "1.3.8",
  "description": "Git-style Google Drive sync CLI with interactive TUI",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CCJ-0617/Aethel.git"
  },
  "homepage": "https://github.com/CCJ-0617/Aethel#readme",
  "bugs": {
    "url": "https://github.com/CCJ-0617/Aethel/issues"
  },
  "keywords": [
    "google-drive",
    "sync",
    "cli",
    "tui",
    "backup",
    "drive",
    "file-manager"
  ],
  "bin": {
    "aethel": "src/cli.js",
    "aethel_beta": "src/cli.js"
  },
  "files": [
    "src/",
    "scripts/demo.js",
    "scripts/render-demo-gif.py",
    "scripts/render-demo-screenshot.js",
    "docs/setup.gif",
    "docs/init.gif",
    "docs/usage.gif",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "docs/ARCHITECTURE.md",
    ".env.example"
  ],
  "scripts": {
    "demo": "node scripts/demo.js",
    "demo:gif": "python3 scripts/render-demo-gif.py",
    "demo:screenshot": "node scripts/render-demo-screenshot.js",
    "demo:setup": "python3 scripts/generate-cast.py && agg docs/setup.cast docs/setup.gif --font-size 32 --theme dracula",
    "demo:init": "python3 scripts/generate-init-cast.py && agg docs/init.cast docs/init.gif --font-size 32 --theme dracula",
    "demo:usage": "python3 scripts/generate-usage-cast.py && agg docs/usage.cast docs/usage.gif --font-size 32 --theme dracula",
    "start": "node src/cli.js",
    "auth": "node src/cli.js auth",
    "clean": "node src/cli.js clean",
    "install:cli": "bash scripts/install.sh",
    "install:debug": "bash scripts/install-debug.sh",
    "release": "bash scripts/release.sh",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm test && npm run pack:check",
    "test": "node --test",
    "tui": "node src/cli.js tui"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "@types/react": "^19.2.0",
    "commander": "^15.0.0",
    "googleapis": "^173.0.0",
    "ignore": "^7.0.5",
    "ink": "^7.0.5",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "open": "^11.0.0",
    "react": "^19.2.7",
    "react-devtools-core": "^7.0.1",
    "tar": "^7.5.16",
    "yaml": "^2.9.0"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
